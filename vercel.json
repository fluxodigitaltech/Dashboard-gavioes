{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/evo-api/:path*",
      "destination": "https://evo-integracao-api.w12app.com.br/:path*"
    },
    {
      "source": "/evo-integracao/:path*",
      "destination": "https://evo-integracao.w12app.com.br/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/warm-cache",
      "schedule": "0 8 * * *"
    }
  ]
}
