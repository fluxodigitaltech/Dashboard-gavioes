# Gaviões EVO Scraper — env config (gitignored em produção)
#
# Este serviço NÃO usa a API de integração da W12 (a franqueadora não libera
# token Basic pra Gaviões). Ele loga na CONTA WEB do EVO5 como um usuário humano
# (Playwright headless), reusa a sessão e extrai os dados. Mesma técnica do
# dashboard BlueFit.

# === HTTP server ========================================================
PORT=8088
# Bearer token compartilhado entre o dashboard e o scraper. Qualquer requisição
# em /sync* precisa enviar Authorization: Bearer <esse valor>. Gere algo aleatório
# longo (ex: openssl rand -hex 32) e cole o MESMO valor em VITE_SCRAPER_TOKEN
# do dashboard.
SCRAPER_TOKEN=changeme-use-openssl-rand-hex-32

# CORS allow-list (separado por vírgula). Origem do dashboard em prod e dev.
# Ex: http://localhost:5173,https://dashboard.gavioes.com.br
CORS_ORIGINS=http://localhost:5173

# === EVO5 (W12) credentials =============================================
# Login da CONTA WEB da Gaviões no EVO5 (o mesmo que você usa pra entrar no
# painel pelo navegador). NÃO é o token Basic da API de integração.
EVO_LOGIN_URL=https://evo5.w12app.com.br/
EVO_USERNAME=
EVO_PASSWORD=
# Lista de idBranch separados por vírgula (uma scraping job por filial/unidade).
# Pega no EVO5 → URL: /#/app/gavioes/<idBranch>/inicio/geral
EVO_BRANCH_IDS=1
# Tenant slug que aparece na URL (/#/app/<TENANT>/...)
EVO_TENANT=gavioes

# === Browser config =====================================================
# headed=false roda invisível (server). headed=true abre janela (dev/debug).
PLAYWRIGHT_HEADLESS=true
# Timeout pra cada operação Playwright (ms)
PLAYWRIGHT_TIMEOUT_MS=60000
# Onde salvar cookies/auth pra reaproveitar entre runs (evita re-login)
SESSION_DIR=./session

# === NocoDB push ========================================================
# Mesma instância configurada no dashboard da Gaviões.
NOCODB_BASE=
NOCODB_TOKEN=
NOCODB_TABLE_EVO_SNAPSHOT=

# === Cron interno (opcional) ============================================
# Se setado, o scraper roda automaticamente nesse intervalo (em ms).
# 0 = desabilitado (só roda quando dashboard chama /sync).
# Ex: 10800000 = 3h
CRON_INTERVAL_MS=0

# === Logs ===============================================================
LOG_LEVEL=info
NODE_ENV=production
