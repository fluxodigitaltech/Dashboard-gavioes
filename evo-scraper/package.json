{
  "name": "gavioes-evo-scraper",
  "version": "0.1.0",
  "description": "Scraper headless EVO5/W12 (conta Gaviões, sem API) → NocoDB. HTTP-driven (dashboard chama /sync) + cron interno opcional.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "discover": "tsx src/cli/discover.ts",
    "snapshot": "tsx src/cli/snapshot.ts",
    "test:login": "tsx src/cli/test-login.ts",
    "test:api": "tsx src/cli/test-api.ts"
  },
  "dependencies": {
    "dotenv": "^17.0.0",
    "express": "^5.0.1",
    "nanoid": "^5.0.7",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "1.59.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
