# Academia Gaviões 24h — Dashboard — environment variables template
#
# Copy this file to .env (gitignored) and fill in the values for local dev.
# In production (Easypanel/Vercel), configure these as environment variables
# in the platform's UI.
#
# SECURITY WARNING:
#   All variables prefixed with VITE_ are bundled into the public JavaScript
#   shipped to browsers. Any user with DevTools can read them. This is a known
#   architectural limitation — when the backend proxy migration is done these
#   move to server-only env vars (without the VITE_ prefix).
#
# NOTE (rebrand Gaviões): todos os valores específicos do cliente anterior foram
# REMOVIDOS. Preencha com os dados da Academia Gaviões 24h antes de subir.

# === NocoDB ============================================================
# Generate at: https://app.nocodb.com → Account Settings → Tokens
VITE_NOCODB_TOKEN=

# === Meta Marketing API ================================================
# Generate at: https://business.facebook.com → Business Settings → System Users
# Required scopes: ads_read, business_management
VITE_META_ACCESS_TOKEN=

# === W12 Evo (um token por unidade/idBranch) ===========================
# Get from W12 admin panel of each unit: Configurações → Integrações / API
# ATENÇÃO: os nomes abaixo são placeholders da estrutura antiga. Ajuste as
# UNIDADES reais da Gaviões em src/services/evoApi.ts (mapa UNITS) e renomeie
# estas variáveis para casar. O DNS do tenant EVO também está em evoApi.ts.
VITE_EVO_TOKEN_UNIDADE_1=
VITE_EVO_TOKEN_UNIDADE_2=
VITE_EVO_TOKEN_UNIDADE_3=

# === Convite por e-mail (backend server/index.mjs — RUNTIME, sem VITE_) =====
# Estas são lidas pelo mini-backend Node em runtime (NÃO vão no bundle do
# navegador). No Easypanel, configure no Environment do serviço do dashboard.
SMTP_ADDRESS=                          # host do SMTP (ex: smtp.hostinger.com)
SMTP_PORT=587                          # 587 (STARTTLS) ou 465 (SSL)
SMTP_USERNAME=                         # usuário/login do SMTP
SMTP_PASSWORD=                         # senha do SMTP (NUNCA commitar)
MAILER_SENDER_EMAIL=                   # e-mail remetente (ex: ti@gavioes.com.br)
FRONTEND_URL=https://seu-dashboard.com # URL pública do dashboard (pro link do convite)
PLATFORM_NAME=Gaviões                  # nome exibido no e-mail
# INVITE_TTL_HOURS=72                   # (opcional) validade do link, em horas

# === Histórico de membros (NocoDB self-hosted — RUNTIME, sem VITE_) =========
# Tabela "Membros" (1 linha por contrato × competência) agregada pelo mini-
# backend em /api/history. Configure no Environment do Easypanel; o token
# NUNCA vai pro bundle do navegador. IDs do cliente anterior REMOVIDOS.
NOCODB_HISTORY_BASE=                    # ex: https://SEU-nocodb.host/api/v2
NOCODB_HISTORY_TOKEN=                  # token do NocoDB self-hosted
NOCODB_HISTORY_TABLE=                  # table ID da tabela Membros
NOCODB_RECEB_TABLE=                    # table ID da tabela Recebimentos (Faturamento Real)
NOCODB_LEADS_TABLE=                    # table ID da tabela LeadsReport (webhook do Fluxo)
NOCODB_LEADS_ROWS_TABLE=               # table ID da tabela Leads (1 linha por lead)
NOCODB_CONV_TABLE=                     # table ID da tabela LeadConversoes
# NOCODB_BASE_ID=                       # base do NocoDB (DashSnapshot/VendasEvo são auto-criadas nela)
# NOCODB_SNAPSHOT_TABLE=                # (opcional) força o ID da DashSnapshot
# NOCODB_VENDAS_TABLE=                  # (opcional) força o ID da VendasEvo
LEADS_WEBHOOK_SECRET=                  # secret exibido ao cadastrar o webhook no Fluxo
# Pull sob demanda da API do Fluxo (traz leads AGORA + reprocessa meses fechados)
# FLUXO_API_BASE=https://atendimento.fluxodigitaltech.com.br
FLUXO_API_TOKEN=                       # token de Agent Bot (recomendado) ou de admin
FLUXO_ACCOUNT_ID=                      # account_id da conta no Fluxo
# NOCODB_HISTORY_TTL_HOURS=6            # (opcional) cache da agregação em horas

# RATE_LIMIT_MAX=10                      # (opcional) req/janela por IP em /api/invite e /api/set-password
# RATE_LIMIT_WINDOW_MS=60000             # (opcional) tamanho da janela do rate-limit, em ms
# NOCODB_TOKEN=                         # (opcional) token do NocoDB pro backend;
#                                       #  se vazio, usa o VITE_NOCODB_TOKEN do runtime
